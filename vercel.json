{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/docs/", "destination": "/" },
    { "source": "/docs/:path*", "destination": "/:path*" }
  ],
  "functions": {
    "api/ask.ts": {
      "maxDuration": 60,
      "includeFiles": "public/ask-index.bin,public/ask-index.meta.json"
    }
  }
}

  more:       '<circle cx="5" cy="12" r="1.6" fill="currentColor"/><circle cx="12" cy="12" r="1.6" fill="currentColor"/><circle cx="19" cy="12" r="1.6" fill="currentColor"/>',
};

// Which path containers to render. Arcus has the Ad-Hoc/Sprint toggle; Suite is
// a single flow with no toggle.
const PATHS: { key: string; steps: Step[] }[] = product === 'suite'
  ? [{ key: 'suite', steps: SUITE_STEPS }]
  : [{ key: 'adhoc', steps: ADHOC_STEPS }, { key: 'sprint', steps: SPRINT_STEPS }];

---

<div class="qi-wrap" id="qi-wrap" data-qi-product={product}>

  <p class="qi-title">
    {product === 'suite'
      ? 'Your testing workflow, end to end'
      : <Fragment>Quality Intelligence is <s class="qi-strike">almost</s> here!</Fragment>}
  </p>

  {product === 'arcus' && (
    <div class="qi-toggle" role="group" aria-label="Select path">
      <button class="qi-toggle-btn qi-toggle-btn--active" data-path="adhoc" aria-pressed="true">
        <svg class="qi-toggle-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="4" y1="21" x2="4" y2="14"/><line x1="4" y1="10" x2="4" y2="3"/>
          <line x1="12" y1="21" x2="12" y2="12"/><line x1="12" y1="8" x2="12" y2="3"/>
          <line x1="20" y1="21" x2="20" y2="16"/><line x1="20" y1="12" x2="20" y2="3"/>
          <line x1="1" y1="14" x2="7" y2="14"/><line x1="9" y1="8" x2="15" y2="8"/><line x1="17" y1="16" x2="23" y2="16"/>
        </svg>
        <span class="qi-toggle-name">Ad-Hoc</span>
        <span class="qi-toggle-sub">Manually attach context &amp; generate</span>
      </button>
      <button class="qi-toggle-btn" data-path="sprint" aria-pressed="false">
        <svg class="qi-toggle-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
        </svg>
        <span class="qi-toggle-name">Sprint</span>
        <span class="qi-toggle-sub">Auto-triggered when sprint starts</span>
      </button>
    </div>
  )}

  <div class="qi-panel" id="qi-panel">
    <!-- Steps rendered per path; JS toggles visibility via data-path on the container -->
    {PATHS.map(({ key: path, steps }, pathIdx) => {
      return (
        <div class="qi-path-steps" data-path={path} aria-hidden={pathIdx === 0 ? 'false' : 'true'} style={pathIdx === 0 ? '' : 'display:none'}>
          {steps.map((step, i) => (
            <div class="qi-step" data-index={i} data-state={i === 0 ? 'active' : 'pending'} data-first={i === 0 ? 'true' : undefined} data-last={i === steps.length - 1 ? 'true' : undefined} data-tall={step.cards ? 'true' : undefined}>
              {/* Continuous connector line — absolutely positioned, split at the node centre */}
              <span class="qi-connector qi-connector--top"></span>
              <span class="qi-connector qi-connector--bot"><span class="qi-loadbar"></span></span>

              {step.group && <div class="qi-group-label">{step.group}</div>}

              <div class="qi-step-body">
                <div class="qi-node" data-dashed={step.dashed ? 'true' : undefined}>
                  <span class="qi-spin-arc"></span>
                  <svg class="qi-node-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={STEP_ICONS[step.icon] ?? STEP_ICONS['clipboard']} />
                  <svg class="qi-node-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={CHECK_PATH} />
                </div>
                <div class="qi-content">
                  <div class="qi-title-row">
                    <span class="qi-step-title">{step.title}</span>
                    <span class="qi-dots" aria-hidden="true"><span></span><span></span><span></span></span>
                  </div>
                  {step.subtitle && <div class="qi-subtitle">{step.subtitle}</div>}
                  <div class="qi-result">
                    <svg class="qi-result-dot" viewBox="0 0 8 8" aria-hidden="true"><circle cx="4" cy="4" r="3" fill="currentColor"/></svg>
                    <span>{step.resultText}</span>
                  </div>
                  {step.pills.length > 0 && (
                    <div class="qi-pills">
                      {step.pills.map(pill => (
                        <span class="qi-pill">
                          <svg class="qi-pill-icon" viewBox="0 0 24 24" aria-hidden="true" set:html={PILL_ICONS[pill.icon] ?? ''} />
                          {pill.label}
                        </span>
                      ))}
                    </div>
                  )}
                  {step.cards && step.cards.length > 0 && (
                    <div class="qi-cards">
                      {step.cards.map(card => (
                        <div class={`qi-card qi-card--${card.accent}`}>
                          <span class="qi-card-pill">
                            <svg class="qi-pill-icon" viewBox="0 0 24 24" aria-hidden="true" set:html={PILL_ICONS[card.icon] ?? STEP_ICONS[card.icon] ?? ''} />
                            {card.label}
                          </span>
                          <div class="qi-mini">
                            <span class="qi-mini-fill" aria-hidden="true"></span>
                            {card.items.map((it, idx) => (
                              <div class="qi-mini-item" style={`--qi-i:${idx}`}><span class="qi-mini-node"></span><span>{it}</span></div>
                            ))}
                          </div>
                        </div>
                      ))}
                    </div>
                  )}
                  {step.handoff && (
                    <div class="qi-handoff">
                      <span class="qi-handoff-flow">
                        <span class={`qi-card-pill qi-card-pill--${step.handoff.fromAccent}`}>
                          <svg class="qi-pill-icon" viewBox="0 0 24 24" aria-hidden="true" set:html={PILL_ICONS[step.handoff.fromIcon] ?? STEP_ICONS[step.handoff.fromIcon] ?? ''} />
                          {step.handoff.fromLabel}
                        </span>
                        <svg class="qi-handoff-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                        <span class={`qi-card-pill qi-card-pill--${step.handoff.toAccent}`}>
                          <svg class="qi-pill-icon" viewBox="0 0 24 24" aria-hidden="true" set:html={PILL_ICONS[step.handoff.toIcon] ?? STEP_ICONS[step.handoff.toIcon] ?? ''} />
                          {step.handoff.toLabel}
                        </span>
                      </span>
                      <span class="qi-handoff-text">{step.handoff.text}</span>
                    </div>
                  )}
                  {step.badges.length > 0 && (
                    <div class="qi-badges">
                      {step.badges.map(b => <span class="qi-badge">{b}</span>)}
                    </div>
                  )}
                </div>
              </div>
            </div>
          ))}
        </div>
      );
    })}
  </div>

</div>

<script>
// JS only toggles data-state on pre-rendered elements and switches path visibility.
// No innerHTML needed — all HTML is Astro-rendered with proper scope classes.

// The visible path container's key (Arcus: 'adhoc'|'sprint', Suite: 'suite').
let currentPath: string = document.querySelector<HTMLElement>('.qi-path-steps')?.dataset.path ?? 'adhoc';
let activeIdx = 0;
let rafPending = false;

function getStepCount(): number {
  const container = document.querySelector<HTMLElement>(`.qi-path-steps[data-path="${currentPath}"]`);
  return container ? container.querySelectorAll('.qi-step').length : 11;
}

// Match the timeline panel's height to the doc-cards column so the steps spread
// over the same length and scroll in step with the cards.
function matchCardsLength() {
  const panel = document.getElementById('qi-panel');
  const cards = document.querySelector<HTMLElement>('.ts-home');
  if (!panel || !cards) return;
  // Span from where the panel starts down to the bottom of the last card, so
  // the final step lands beside the last card.
  const panelTop = panel.getBoundingClientRect().top + window.scrollY;
  const cardsBottom = cards.getBoundingClientRect().bottom + window.scrollY;
  const h = Math.max(cards.offsetHeight, cardsBottom - panelTop);
  panel.style.height = `${h}px`;
}

// Measure each node's centre (offset from the top of its step) so the absolute
// connector line splits exactly at the node — keeps the line continuous through
// the group-label gaps regardless of step height.
function measureNodes() {
  document.querySelectorAll<HTMLElement>('.qi-path-steps').forEach(container => {
    container.querySelectorAll<HTMLElement>('.qi-step').forEach(step => {
      const node = step.querySelector<HTMLElement>('.qi-node');
      if (!node) return;
      const c = node.offsetTop + node.offsetHeight / 2;
      step.style.setProperty('--qi-c', `${c}px`);
    });
  });
}

function applyActiveIndex(idx: number) {
  activeIdx = idx;
  const container = document.querySelector<HTMLElement>(`.qi-path-steps[data-path="${currentPath}"]`);
  if (!container) return;

  const stepEls = container.querySelectorAll<HTMLElement>('.qi-step');
  stepEls.forEach((el, i) => {
    el.dataset.state = i < idx ? 'done' : i === idx ? 'active' : 'pending';
  });
  // The rail flows with the page now, so the active step scrolls into view
  // naturally with the doc cards — no internal panel scrolling needed.
}

function computeIdx(): number {
  const total = document.documentElement.scrollHeight - window.innerHeight;
  if (total <= 0) return 0;
  const p = Math.max(0, Math.min(1, window.scrollY / total));
  const n = getStepCount();
  // Allow the index to reach n (one past the last step) so that at the bottom
  // of the page every step — including the last — resolves to "done".
  return Math.min(Math.floor(p * (n + 1)), n);
}

function onScroll() {
  if (rafPending) return;
  rafPending = true;
  requestAnimationFrame(() => {
    rafPending = false;
    const newIdx = computeIdx();
    if (newIdx !== activeIdx) applyActiveIndex(newIdx);
  });
}

function switchPath(path: string) {
  currentPath = path;
  document.querySelectorAll<HTMLElement>('.qi-path-steps').forEach(el => {
    const isActive = el.dataset.path === path;
    el.style.display = isActive ? '' : 'none';
    el.setAttribute('aria-hidden', isActive ? 'false' : 'true');
  });
  matchCardsLength();
  measureNodes();
  applyActiveIndex(computeIdx());
}

function initToggle() {
  document.querySelectorAll<HTMLButtonElement>('.qi-toggle-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll<HTMLButtonElement>('.qi-toggle-btn').forEach(b => {
        b.classList.remove('qi-toggle-btn--active');
        b.setAttribute('aria-pressed', 'false');
      });
      btn.classList.add('qi-toggle-btn--active');
      btn.setAttribute('aria-pressed', 'true');
      switchPath(btn.dataset.path ?? 'adhoc');
    });
  });
}

let resizeRaf = false;
function onResize() {
  if (resizeRaf) return;
  resizeRaf = true;
  requestAnimationFrame(() => {
    resizeRaf = false;
    matchCardsLength();
    measureNodes();
  });
}

function boot() {
  initToggle();
  matchCardsLength();
  measureNodes();
  const pref = window.matchMedia('(prefers-reduced-motion: reduce)');
  if (!pref.matches) {
    window.addEventListener('scroll', onScroll, { passive: true });
  }
  window.addEventListener('resize', onResize, { passive: true });
  // Re-measure after web fonts settle (text reflow shifts heights/node positions)
  if (document.fonts && document.fonts.ready) {
    document.fonts.ready.then(() => { matchCardsLength(); measureNodes(); });
  }
  applyActiveIndex(computeIdx());
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', boot);
} else {
  boot();
}
</script>

<style>
.qi-wrap {
  font-family: var(--sl-font);
  font-size: 13px;
  color: var(--ts-text-primary);
  /* Align the title row with the hero title, which sits below the hero's top
     padding. */
  padding-top: 40px;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;

  /* ── Accent tokens (Arcus defaults — violet "done", dark-teal "active") ── */
  --qi-active:        #093F4D;  /* active ring / icon / dots / spinner */
  --qi-active-bg:     #ffffff;  /* active node fill */
  --qi-done:          #6E45DF;  /* done accent — connectors, pill outline */
  --qi-done-node-bg:  #6E45DF;  /* done node fill (solid for Arcus) */
  --qi-done-check:    #ffffff;  /* checkmark colour */
  --qi-done-text:     #5B23D6;  /* done pill text */
  --qi-grad:          linear-gradient(135deg, #E58086, #5C27F5);
  --qi-result-text:   var(--ts-text-secondary);
  --qi-result-dot:    #1F8A5B;  /* green status dot */
  --qi-result-dot-display: inline;
}

/* ── Suite: strict Suite teal palette, softer node style ── */
.qi-wrap[data-qi-product='suite'] {
  --qi-active:        #00B2BD;
  --qi-active-bg:     #E0F7F9;
  --qi-done:          #00B2BD;
  --qi-done-node-bg:  #E0F7F9;  /* light teal fill (soft, not solid) */
  --qi-done-check:    #0B7C84;  /* dark-teal check */
  --qi-done-text:     #0B7C84;
  --qi-grad:          linear-gradient(135deg, #00B2BD, #07C0A1);
  --qi-result-text:   #0B7C84;  /* result reads as a teal status label */
  --qi-result-dot-display: none;
}

.qi-title {
  font-size: 20px;
  font-weight: 700;
  color: #091E42;
  margin: 0 0 14px;
  line-height: 1.25;
  letter-spacing: -0.01em;
}
.qi-strike {
  text-decoration-thickness: 2px;
  text-decoration-color: var(--ts-text-tertiary);
  color: var(--ts-text-tertiary);
}

/* ── Toggle ── */
.qi-toggle {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
  margin-bottom: 16px;
}
.qi-toggle-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  padding: 12px 8px 10px;
  border: 1.5px solid var(--ts-border-strong);
  border-radius: 10px;
  background: #fff;
  cursor: pointer;
  text-align: center;
  transition: border-color 0.15s, background 0.15s;
}
.qi-toggle-btn--active {
  background: linear-gradient(180deg,
    color-mix(in srgb, #E58086 8%, #fff),
    color-mix(in srgb, #5C27F5 8%, #fff)
  );
  border-color: #6E45DF;
}
.qi-toggle-icon {
  width: 18px;
  height: 18px;
  flex-shrink: 0;
  color: var(--ts-text-secondary);
}
.qi-toggle-btn--active .qi-toggle-icon { color: #9F57C0; }
.qi-toggle-name {
  font-size: 13px;
  font-weight: 700;
  line-height: 1.2;
  color: var(--ts-text-primary);
}
.qi-toggle-btn--active .qi-toggle-name {
  background: linear-gradient(135deg, #E58086, #5C27F5);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.qi-toggle-sub {
  font-size: 11px;
  line-height: 1.4;
  color: var(--ts-text-secondary);
}

/* ── Panel ── */
/* The panel flows with the page (no internal scroll). Its height is set in JS
   to match the doc-cards column, so the steps spread to the same length and
   scroll with the cards. */
.qi-panel {
  display: flex;
  flex-direction: column;
}
.qi-path-steps {
  display: flex;
  flex-direction: column;
  flex: 1 1 auto;
  min-height: 0;
}
/* Steps fill the matched panel height as equal slots, staying edge-to-edge so
   the connector line stays continuous (gaps would break the absolute line).
   flex-basis:0 + min-height:0 makes each slot's height independent of its
   content — so revealing pills/badges on state change doesn't reflow the other
   steps (which otherwise causes the timeline to "shake" while scrolling). The
   last step keeps its natural height so it lands at the bottom. */
.qi-path-steps > .qi-step { flex: 1 1 0; min-height: 0; }
.qi-path-steps > .qi-step[data-last] { flex: 0 0 auto; }
/* A step with sub-cards needs a taller slot; grow weight (not content) sets the
   height, so it stays reflow-free and the cards never overflow the next step. */
.qi-path-steps > .qi-step[data-tall] { flex-grow: 3.2; }

/* ── Step ── */
/* Node centre offset (measured by JS) drives where the connector line splits.
   --qi-c = distance from the top of the step to the node centre. */
.qi-step {
  position: relative;
  --qi-c: 28px;
  --qi-node-x: 16px; /* node centre x = 32/2 */
}

.qi-group-label {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--ts-text-tertiary);
  padding: 12px 0 5px 44px;
}
.qi-step[data-first] .qi-group-label { padding-top: 2px; }

.qi-step-body {
  display: flex;
  gap: 12px;
  align-items: flex-start;
  padding-bottom: 4px;
}

/* ── Continuous connector line (absolute, split at node centre) ── */
.qi-connector {
  position: absolute;
  left: var(--qi-node-x);
  width: 1.5px;
  transform: translateX(-50%);
  background: #DAE0E6;
  transition: background 0.35s;
  z-index: 0;
}
.qi-connector--top { top: 0; height: var(--qi-c); }
.qi-connector--bot { top: var(--qi-c); bottom: 0; overflow: hidden; }

/* First step: nothing above its node. Last step: nothing below. */
.qi-step[data-first] .qi-connector--top { display: none; }
.qi-step[data-last]  .qi-connector--bot { display: none; }

/* Line above a node is filled once that step is reached (active or done). */
.qi-step[data-state="active"] .qi-connector--top,
.qi-step[data-state="done"]   .qi-connector--top { background: var(--qi-done); }

/* Line below a done node is filled (links to the next done/active node). */
.qi-step[data-state="done"] .qi-connector--bot { background: var(--qi-done); }

/* Line below the ACTIVE node = the "loading" element: an accent bar travels
   down it until scroll advances to the next step. */
.qi-loadbar {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg,
    var(--qi-done) 0%,
    var(--qi-done) 35%,
    color-mix(in srgb, var(--qi-done) 0%, transparent) 70%);
  transform: translateY(-100%);
  opacity: 0;
}
.qi-step[data-state="active"] .qi-loadbar {
  opacity: 1;
  animation: qi-load 1.6s ease-in-out infinite;
}

/* Node */
.qi-node {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: #fff;
  border: 1.5px solid #C1C7D0;
  transition: border-color 0.25s, background 0.25s, box-shadow 0.25s, opacity 0.25s;
}
.qi-step[data-state="pending"] .qi-node { opacity: 0.45; }
.qi-step[data-state="active"]  .qi-node {
  background: var(--qi-active-bg);
  border-color: var(--qi-active);
  border-width: 2px;
  box-shadow: 0 0 0 3px color-mix(in srgb, var(--qi-active) 12%, transparent);
}
.qi-step[data-state="done"] .qi-node {
  background: var(--qi-done-node-bg);
  border-color: var(--qi-done);
}

/* Dashed ring for "when detected" step */
.qi-step[data-state="pending"] .qi-node[data-dashed],
.qi-step[data-state="active"]  .qi-node[data-dashed] {
  border-style: dashed;
}

.qi-node-icon {
  width: 14px;
  height: 14px;
  color: var(--ts-text-tertiary);
  transition: color 0.2s;
  position: relative;
  z-index: 1;
}
.qi-step[data-state="active"] .qi-node-icon {
  color: var(--qi-active);
  animation: qi-pulse 2s ease-in-out infinite;
}
.qi-step[data-state="done"] .qi-node-icon { display: none; }

.qi-node-check {
  width: 14px;
  height: 14px;
  color: var(--qi-done-check);
  display: none;
  position: relative;
  z-index: 1;
}
.qi-step[data-state="done"] .qi-node-check { display: block; }

/* Spin arc */
.qi-spin-arc {
  position: absolute;
  inset: -3px;
  border-radius: 50%;
  border: 2px solid transparent;
  border-top-color: var(--qi-active);
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.2s;
}
.qi-step[data-state="active"] .qi-spin-arc {
  opacity: 1;
  animation: qi-spin 1s linear infinite;
}

/* ── Content ── */
.qi-content {
  flex: 1;
  min-width: 0;
  padding-top: 6px;
  padding-bottom: 10px;
  transition: opacity 0.2s;
}
.qi-step[data-state="pending"] .qi-content { opacity: 0.45; }

.qi-title-row {
  display: flex;
  align-items: center;
  gap: 4px;
  flex-wrap: wrap;
  line-height: 1.3;
}
.qi-step-title {
  font-size: 13px;
  font-weight: 600;
  color: var(--ts-text-primary);
  letter-spacing: -0.01em;
}

/* Blinking dots */
.qi-dots {
  display: none;
  gap: 2px;
  align-items: center;
}
.qi-step[data-state="active"] .qi-dots { display: inline-flex; }
.qi-dots span {
  width: 3px;
  height: 3px;
  border-radius: 50%;
  background: var(--qi-active);
  animation: qi-blink 1.2s ease-in-out infinite;
}
.qi-dots span:nth-child(2) { animation-delay: 0.2s; }
.qi-dots span:nth-child(3) { animation-delay: 0.4s; }

/* Subtitle */
.qi-subtitle {
  display: none;
  font-size: 11.5px;
  color: var(--ts-text-secondary);
  line-height: 1.4;
  margin-top: 2px;
}
.qi-step[data-state="active"] .qi-subtitle,
.qi-step[data-state="done"]   .qi-subtitle { display: block; }

/* Result chip */
.qi-result {
  display: none;
  align-items: center;
  gap: 4px;
  font-size: 11.5px;
  color: var(--qi-result-text);
  font-weight: 600;
  margin-top: 3px;
}
.qi-step[data-state="done"] .qi-result { display: flex; }
.qi-result-dot {
  display: var(--qi-result-dot-display);
  width: 8px;
  height: 8px;
  color: var(--qi-result-dot);
  flex-shrink: 0;
}

/* Pills */
.qi-pills {
  display: none;
  flex-wrap: wrap;
  gap: 4px;
  margin-top: 6px;
}
.qi-step[data-state="active"] .qi-pills,
.qi-step[data-state="done"]   .qi-pills { display: flex; }

.qi-pill {
  display: inline-flex;
  align-items: center;
  gap: 4px;

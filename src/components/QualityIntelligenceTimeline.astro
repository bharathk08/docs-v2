  { group: 'AUTOMATION', title: 'Learn & automate', subtitle: 'Executing and self-healing flaky steps', resultText: '31 passed · 3 healed', pills: [], badges: ['RUNNER', 'HEALER'], icon: 'bot', dashed: false },
  { group: null, title: 'Automatically detect gaps', subtitle: 'Scanning for uncovered paths', resultText: '2 gaps found', pills: [], badges: ['ANALYZER'], icon: 'radar', dashed: false },
  { group: 'QUALITY', title: 'Decide release readiness', subtitle: 'Aggregating signals', resultText: 'Readiness 94%', pills: [], badges: [], icon: 'clipboard', dashed: false },
  { group: null, title: 'Release ready', subtitle: 'All checks passed', resultText: 'Cleared to ship', pills: [], badges: [], icon: 'rocket', dashed: false },
];

// Both paths share the same tail; only entry step differs
const ADHOC_STEPS = [ADHOC_ENTRY, ...SHARED_STEPS];
const SPRINT_STEPS = [SPRINT_ENTRY, ...SHARED_STEPS];


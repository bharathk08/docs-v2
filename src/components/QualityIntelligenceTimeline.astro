---
// QualityIntelligenceTimeline.astro — Scroll-driven QI timeline for Arcus home

interface Step {
  group: string | null;
  title: string;
  subtitle: string;
  resultText: string;
  pills: { label: string; icon: string }[];
  badges: string[];
  icon: string;
  dashed: boolean;
  entryPath?: 'adhoc' | 'sprint';
}

const ADHOC_ENTRY: Step = {
  group: 'ENTRY', title: 'Ad-Hoc Run',
  subtitle: 'A single test case, run on demand', resultText: 'Path selected',
  pills: [{ label: 'Jira', icon: 'jira' }, { label: 'Figma', icon: 'figma' }, { label: 'Files', icon: 'files' }, { label: 'Video', icon: 'video' }],
  badges: [], icon: 'sliders', dashed: false, entryPath: 'adhoc',
};
const SPRINT_ENTRY: Step = {
  group: 'ENTRY', title: 'Sprint Run',
  subtitle: 'Auto-triggered when sprint starts', resultText: 'Sprint started',
  pills: [{ label: 'Jira', icon: 'jira' }, { label: 'GitHub', icon: 'github' }],
  badges: [], icon: 'bolt', dashed: false, entryPath: 'sprint',
};

const SHARED_STEPS: Step[] = [
  { group: 'SESSION', title: 'In Progress', subtitle: 'Session active', resultText: 'Session active', pills: [], badges: [], icon: 'spinner', dashed: false },
  { group: 'PROCESSING CONTEXT', title: 'Processing Jira stories', subtitle: 'Acceptance criteria & linked tickets', resultText: '12 stories parsed', pills: [{ label: 'Jira', icon: 'jira' }, { label: 'Confluence', icon: 'confluence' }], badges: [], icon: 'list', dashed: false },
  { group: null, title: 'Reading Figma designs', subtitle: '8 frames loaded', resultText: '8 frames read', pills: [{ label: 'Figma', icon: 'figma' }, { label: 'Files', icon: 'files' }], badges: [], icon: 'layers', dashed: false },
  { group: null, title: 'Watching video for context', subtitle: 'Capturing context from recording', resultText: 'Context captured', pills: [], badges: [], icon: 'video', dashed: false },
  { group: 'GENERATION', title: 'Generates tests, runs & plans', subtitle: 'Building test cases from context', resultText: '34 tests · 6 plans', pills: [], badges: ['GENERATOR'], icon: 'pen', dashed: false },
  { group: 'SESSION MAPPING · WHEN DETECTED', title: 'Claude session / GitHub PR detected', subtitle: 'Mapping to open PR', resultText: 'PR #482 mapped', pills: [{ label: 'Claude', icon: 'claude' }, { label: 'GitHub', icon: 'github' }], badges: [], icon: 'git-merge', dashed: true },
  { group: 'AUTOMATION', title: 'Learn & automate', subtitle: 'Executing and self-healing flaky steps', resultText: '31 passed · 3 healed', pills: [], badges: ['RUNNER', 'HEALER'], icon: 'bot', dashed: false },
  { group: null, title: 'Automatically detect gaps', subtitle: 'Scanning for uncovered paths', resultText: '2 gaps found', pills: [], badges: ['ANALYZER'], icon: 'radar', dashed: false },
  { group: 'QUALITY', title: 'Decide release readiness', subtitle: 'Aggregating signals', resultText: 'Readiness 94%', pills: [], badges: [], icon: 'clipboard', dashed: false },
  { group: null, title: 'Release ready', subtitle: 'All checks passed', resultText: 'Cleared to ship', pills: [], badges: [], icon: 'rocket', dashed: false },
];

// Both paths share the same tail; only entry step differs
const ADHOC_STEPS = [ADHOC_ENTRY, ...SHARED_STEPS];
const SPRINT_STEPS = [SPRINT_ENTRY, ...SHARED_STEPS];

const STEP_ICONS: Record<string, string> = {
  sliders:    '<line x1="4" y1="21" x2="4" y2="14"/><line x1="4" y1="10" x2="4" y2="3"/><line x1="12" y1="21" x2="12" y2="12"/><line x1="12" y1="8" x2="12" y2="3"/><line x1="20" y1="21" x2="20" y2="16"/><line x1="20" y1="12" x2="20" y2="3"/><line x1="1" y1="14" x2="7" y2="14"/><line x1="9" y1="8" x2="15" y2="8"/><line x1="17" y1="16" x2="23" y2="16"/>',
  bolt:       '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>',
  spinner:    '<path d="M21 12a9 9 0 1 1-6.219-8.56"/>',
  list:       '<line x1="9" y1="6" x2="20" y2="6"/><line x1="9" y1="12" x2="20" y2="12"/><line x1="9" y1="18" x2="20" y2="18"/><line x1="4" y1="6" x2="4.01" y2="6"/><line x1="4" y1="12" x2="4.01" y2="12"/><line x1="4" y1="18" x2="4.01" y2="18"/>',
  layers:     '<polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>',
  video:      '<path d="m22 8-6 4 6 4V8z"/><rect x="2" y="6" width="14" height="12" rx="2" ry="2"/>',
  pen:        '<path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>',
  'git-merge':'<circle cx="18" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><path d="M6 21V9a9 9 0 0 0 9 9"/>',
  bot:        '<rect x="3" y="11" width="18" height="10" rx="2"/><circle cx="12" cy="5" r="2"/><path d="M12 7v4"/><line x1="8" y1="16" x2="8.01" y2="16"/><line x1="16" y1="16" x2="16.01" y2="16"/>',
  radar:      '<path d="M19.07 4.93A10 10 0 0 0 6.99 3.34"/><path d="M4 6h.01"/><path d="M2.29 9.62A10 10 0 1 0 21.31 8.35"/><path d="M16.24 7.76A6 6 0 1 0 8.23 16.67"/><path d="M12 18h.01"/><path d="M17.99 11.66A6 6 0 0 1 15.77 16.67"/><circle cx="12" cy="12" r="2"/><path d="m13.41 10.59 5.66-5.66"/>',
  clipboard:  '<path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/>',
  rocket:     '<path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/>',
};

const CHECK_PATH = '<polyline points="20 6 9 17 4 12"/>';

const PILL_ICONS: Record<string, string> = {
  jira:       '<path fill="currentColor" d="M11.53 2c0 2.4 1.97 4.35 4.35 4.35h1.78v1.7c0 2.4 1.96 4.34 4.34 4.35V2.84a.84.84 0 0 0-.84-.84h-9.63zm-4.47 4.35c0 2.4 1.96 4.34 4.35 4.35h1.77v1.7a4.35 4.35 0 0 0 4.35 4.35V7.19a.84.84 0 0 0-.84-.84H7.06zm-4.48 4.35A4.35 4.35 0 0 0 6.93 15h1.78v1.7a4.35 4.35 0 0 0 4.34 4.35v-8.51a.84.84 0 0 0-.84-.84H2.58z"/>',
  figma:      '<path fill="currentColor" d="M5 5.5A3.5 3.5 0 0 1 8.5 2H12v7H8.5A3.5 3.5 0 0 1 5 5.5zM12 2h3.5a3.5 3.5 0 1 1 0 7H12V2zM12 12.5a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0zM5 19.5A3.5 3.5 0 0 1 8.5 16H12v3.5a3.5 3.5 0 1 1-7 0zM5 12.5A3.5 3.5 0 0 1 8.5 9H12v7H8.5A3.5 3.5 0 0 1 5 12.5z"/>',
  confluence: '<path fill="currentColor" d="M2.228 17.299c-.24.39-.054.882.36 1.07l5.195 2.322c.396.177.86.018 1.06-.363C10.27 18.19 11.574 17.5 13 17.5s2.73.69 4.157 2.828c.2.381.664.54 1.06.363l5.195-2.322c.414-.188.6-.68.36-1.07C21.576 14.645 17.828 12.5 13 12.5s-8.576 2.145-10.772 4.799zm21.544-10.598c.24-.39.054-.882-.36-1.07l-5.195-2.322c-.396-.177-.86-.018-1.06.363C15.73 5.81 14.426 6.5 13 6.5S10.27 5.81 8.843 3.672c-.2-.381-.664-.54-1.06-.363L2.588 5.631c-.414.188-.6.68-.36 1.07C4.424 9.355 8.172 11.5 13 11.5s8.576-2.145 10.772-4.799z"/>',
  claude:     '<path fill="currentColor" d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/>',
  github:     '<path fill="currentColor" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>',
  files:      '<path stroke="currentColor" stroke-width="1.5" fill="none" d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline stroke="currentColor" stroke-width="1.5" fill="none" points="14 2 14 8 20 8"/>',
  video:      '<path stroke="currentColor" stroke-width="1.5" fill="none" d="m22 8-6 4 6 4V8z"/><rect stroke="currentColor" stroke-width="1.5" fill="none" x="2" y="6" width="14" height="12" rx="2"/>',
};

// Render both paths; JS hides/shows via data-entry-path attribute on steps
const ALL_STEPS = [...ADHOC_STEPS, ...SPRINT_STEPS];
---

<div class="qi-wrap" id="qi-wrap">

  <p class="qi-title">Quality Intelligence is <s class="qi-strike">almost</s> here!</p>

  <div class="qi-toggle" role="group" aria-label="Select path">
    <button class="qi-toggle-btn qi-toggle-btn--active" data-path="adhoc" aria-pressed="true">
      <svg class="qi-toggle-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="4" y1="21" x2="4" y2="14"/><line x1="4" y1="10" x2="4" y2="3"/>
        <line x1="12" y1="21" x2="12" y2="12"/><line x1="12" y1="8" x2="12" y2="3"/>
        <line x1="20" y1="21" x2="20" y2="16"/><line x1="20" y1="12" x2="20" y2="3"/>
        <line x1="1" y1="14" x2="7" y2="14"/><line x1="9" y1="8" x2="15" y2="8"/><line x1="17" y1="16" x2="23" y2="16"/>
      </svg>
      <span class="qi-toggle-name">Ad-Hoc</span>
      <span class="qi-toggle-sub">Manually attach context &amp; generate</span>
    </button>
    <button class="qi-toggle-btn" data-path="sprint" aria-pressed="false">
      <svg class="qi-toggle-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
      </svg>
      <span class="qi-toggle-name">Sprint</span>
      <span class="qi-toggle-sub">Auto-triggered when sprint starts</span>
    </button>
  </div>

  <div class="qi-panel" id="qi-panel">
    <!-- Steps rendered per path; JS toggles visibility via data-path on the container -->
    {(['adhoc', 'sprint'] as const).map((path) => {
      const steps = path === 'adhoc' ? ADHOC_STEPS : SPRINT_STEPS;
      return (
        <div class="qi-path-steps" data-path={path} aria-hidden={path === 'sprint' ? 'true' : 'false'} style={path === 'sprint' ? 'display:none' : ''}>
          {steps.map((step, i) => (
            <div class="qi-step" data-index={i} data-state={i === 0 ? 'active' : 'pending'} data-first={i === 0 ? 'true' : undefined} data-last={i === steps.length - 1 ? 'true' : undefined}>
              {/* Continuous connector line — absolutely positioned, split at the node centre */}
              <span class="qi-connector qi-connector--top"></span>
              <span class="qi-connector qi-connector--bot"><span class="qi-loadbar"></span></span>

              {step.group && <div class="qi-group-label">{step.group}</div>}

              <div class="qi-step-body">
                <div class="qi-node" data-dashed={step.dashed ? 'true' : undefined}>
                  <span class="qi-spin-arc"></span>
                  <svg class="qi-node-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={STEP_ICONS[step.icon] ?? STEP_ICONS['clipboard']} />
                  <svg class="qi-node-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={CHECK_PATH} />
                </div>
                <div class="qi-content">
                  <div class="qi-title-row">
                    <span class="qi-step-title">{step.title}</span>
                    <span class="qi-dots" aria-hidden="true"><span></span><span></span><span></span></span>
                  </div>
                  {step.subtitle && <div class="qi-subtitle">{step.subtitle}</div>}
                  <div class="qi-result">
                    <svg class="qi-result-dot" viewBox="0 0 8 8" aria-hidden="true"><circle cx="4" cy="4" r="3" fill="currentColor"/></svg>
                    <span>{step.resultText}</span>
                  </div>
                  {step.pills.length > 0 && (
                    <div class="qi-pills">
                      {step.pills.map(pill => (
                        <span class="qi-pill">
                          <svg class="qi-pill-icon" viewBox="0 0 24 24" aria-hidden="true" set:html={PILL_ICONS[pill.icon] ?? ''} />
                          {pill.label}
                        </span>
                      ))}
                    </div>
                  )}
                  {step.badges.length > 0 && (
                    <div class="qi-badges">
                      {step.badges.map(b => <span class="qi-badge">{b}</span>)}
                    </div>
                  )}
                </div>
              </div>
            </div>
          ))}
        </div>
      );
    })}
  </div>

</div>

<script>
// JS only toggles data-state on pre-rendered elements and switches path visibility.
// No innerHTML needed — all HTML is Astro-rendered with proper scope classes.

let currentPath: 'adhoc' | 'sprint' = 'adhoc';
let activeIdx = 0;
let rafPending = false;

function getStepCount(): number {
  const container = document.querySelector<HTMLElement>(`.qi-path-steps[data-path="${currentPath}"]`);
  return container ? container.querySelectorAll('.qi-step').length : 11;
}

// Measure each node's centre (offset from the top of its step) so the absolute
// connector line splits exactly at the node — keeps the line continuous through
// the group-label gaps regardless of step height.
function measureNodes() {
  document.querySelectorAll<HTMLElement>('.qi-path-steps').forEach(container => {
    container.querySelectorAll<HTMLElement>('.qi-step').forEach(step => {
      const node = step.querySelector<HTMLElement>('.qi-node');
      if (!node) return;
      const c = node.offsetTop + node.offsetHeight / 2;
      step.style.setProperty('--qi-c', `${c}px`);
    });
  });
}

function applyActiveIndex(idx: number) {
  activeIdx = idx;
  const container = document.querySelector<HTMLElement>(`.qi-path-steps[data-path="${currentPath}"]`);
  if (!container) return;

  const stepEls = container.querySelectorAll<HTMLElement>('.qi-step');
  stepEls.forEach((el, i) => {
    el.dataset.state = i < idx ? 'done' : i === idx ? 'active' : 'pending';
  });

  // Scroll active step into view within panel
  const activeEl = stepEls[idx];
  const panel = document.getElementById('qi-panel');
  if (panel && activeEl) {
    const panelRect = panel.getBoundingClientRect();
    const elRect = activeEl.getBoundingClientRect();
    if (elRect.bottom > panelRect.bottom - 16) {
      panel.scrollTop += elRect.bottom - panelRect.bottom + 24;
    } else if (elRect.top < panelRect.top + 16) {
      panel.scrollTop -= panelRect.top - elRect.top + 24;
    }
  }
}

function computeIdx(): number {
  const total = document.documentElement.scrollHeight - window.innerHeight;
  if (total <= 0) return 0;
  const p = Math.max(0, Math.min(1, window.scrollY / total));
  const n = getStepCount();
  // Allow the index to reach n (one past the last step) so that at the bottom
  // of the page every step — including the last — resolves to "done".
  return Math.min(Math.floor(p * (n + 1)), n);
}

function onScroll() {
  if (rafPending) return;
  rafPending = true;
  requestAnimationFrame(() => {
    rafPending = false;
    const newIdx = computeIdx();
    if (newIdx !== activeIdx) applyActiveIndex(newIdx);
  });
}

function switchPath(path: 'adhoc' | 'sprint') {
  currentPath = path;
  document.querySelectorAll<HTMLElement>('.qi-path-steps').forEach(el => {
    const isActive = el.dataset.path === path;
    el.style.display = isActive ? '' : 'none';
    el.setAttribute('aria-hidden', isActive ? 'false' : 'true');
  });
  measureNodes();
  applyActiveIndex(computeIdx());
}

function initToggle() {
  document.querySelectorAll<HTMLButtonElement>('.qi-toggle-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll<HTMLButtonElement>('.qi-toggle-btn').forEach(b => {
        b.classList.remove('qi-toggle-btn--active');
        b.setAttribute('aria-pressed', 'false');
      });
      btn.classList.add('qi-toggle-btn--active');
      btn.setAttribute('aria-pressed', 'true');
      switchPath((btn.dataset.path as 'adhoc' | 'sprint') ?? 'adhoc');
    });
  });
}

let resizeRaf = false;
function onResize() {
  if (resizeRaf) return;
  resizeRaf = true;
  requestAnimationFrame(() => {
    resizeRaf = false;
    measureNodes();
  });
}

function boot() {
  initToggle();
  measureNodes();
  const pref = window.matchMedia('(prefers-reduced-motion: reduce)');
  if (!pref.matches) {
    window.addEventListener('scroll', onScroll, { passive: true });
  }
  window.addEventListener('resize', onResize, { passive: true });
  // Re-measure after web fonts settle (text reflow shifts node positions)
  if (document.fonts && document.fonts.ready) {
    document.fonts.ready.then(() => { measureNodes(); });
  }
  applyActiveIndex(computeIdx());
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', boot);
} else {
  boot();
}
</script>

<style>
.qi-wrap {
  font-family: var(--sl-font);
  font-size: 13px;
  color: var(--ts-text-primary);
  /* Align the title row with the "Arcus Documentation" hero title, which sits
     below the hero's top padding. */
  padding-top: 40px;
}

.qi-title {
  font-size: 20px;
  font-weight: 700;
  color: #091E42;
  margin: 0 0 14px;
  line-height: 1.25;
  letter-spacing: -0.01em;
}
.qi-strike {
  text-decoration-thickness: 2px;
  text-decoration-color: var(--ts-text-tertiary);
  color: var(--ts-text-tertiary);
}

/* ── Toggle ── */
.qi-toggle {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
  margin-bottom: 16px;
}
.qi-toggle-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  padding: 12px 8px 10px;
  border: 1.5px solid var(--ts-border-strong);
  border-radius: 10px;
  background: #fff;
  cursor: pointer;
  text-align: center;
  transition: border-color 0.15s, background 0.15s;
}
.qi-toggle-btn--active {
  background: linear-gradient(180deg,
    color-mix(in srgb, #E58086 8%, #fff),
    color-mix(in srgb, #5C27F5 8%, #fff)
  );
  border-color: #6E45DF;
}
.qi-toggle-icon {
  width: 18px;
  height: 18px;
  flex-shrink: 0;
  color: var(--ts-text-secondary);
}
.qi-toggle-btn--active .qi-toggle-icon { color: #9F57C0; }
.qi-toggle-name {
  font-size: 13px;
  font-weight: 700;
  line-height: 1.2;
  color: var(--ts-text-primary);
}
.qi-toggle-btn--active .qi-toggle-name {
  background: linear-gradient(135deg, #E58086, #5C27F5);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.qi-toggle-sub {
  font-size: 11px;
  line-height: 1.4;
  color: var(--ts-text-secondary);
}

/* ── Panel ── */
.qi-panel {
  overflow-y: auto;
  overflow-x: hidden;
  scrollbar-width: none;
  max-height: calc(100vh - 230px);
}
.qi-panel::-webkit-scrollbar { display: none; }

/* ── Step ── */
/* Node centre offset (measured by JS) drives where the connector line splits.
   --qi-c = distance from the top of the step to the node centre. */
.qi-step {
  position: relative;
  --qi-c: 28px;
  --qi-node-x: 16px; /* node centre x = 32/2 */
}

.qi-group-label {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--ts-text-tertiary);
  padding: 12px 0 5px 44px;
}
.qi-step[data-first] .qi-group-label { padding-top: 2px; }

.qi-step-body {
  display: flex;
  gap: 12px;
  align-items: flex-start;
  padding-bottom: 4px;
}

/* ── Continuous connector line (absolute, split at node centre) ── */
.qi-connector {
  position: absolute;
  left: var(--qi-node-x);
  width: 1.5px;
  transform: translateX(-50%);
  background: #DAE0E6;
  transition: background 0.35s;
  z-index: 0;
}
.qi-connector--top { top: 0; height: var(--qi-c); }
.qi-connector--bot { top: var(--qi-c); bottom: 0; overflow: hidden; }

/* First step: nothing above its node. Last step: nothing below. */
.qi-step[data-first] .qi-connector--top { display: none; }
.qi-step[data-last]  .qi-connector--bot { display: none; }

/* Line above a node is filled once that step is reached (active or done). */

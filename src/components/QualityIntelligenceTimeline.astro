---
// QualityIntelligenceTimeline.astro — Scroll-driven QI timeline.
// Product-aware: Arcus (Ad-Hoc/Sprint paths, violet) and Suite (single flow, teal).

export interface Props {
  product?: 'arcus' | 'suite';
}
const { product = 'arcus' } = Astro.props;

interface SubCard {
  label: string;
  icon: string;
  accent: 'a' | 'b';
  items: string[];
}

interface Handoff {
  fromLabel: string; fromIcon: string; fromAccent: 'a' | 'b';
  toLabel: string;   toIcon: string;   toAccent: 'a' | 'b';
  text: string;
}

interface Step {
  group: string | null;
  title: string;
  subtitle: string;
  resultText: string;
  pills: { label: string; icon: string }[];
  badges: string[];
  icon: string;
  dashed: boolean;
  entryPath?: 'adhoc' | 'sprint';
  cards?: SubCard[];
  handoff?: Handoff;
}

const ADHOC_ENTRY: Step = {
  group: 'ENTRY', title: 'Ad-Hoc Run',
  subtitle: 'A single test case, run on demand', resultText: 'Path selected',
  pills: [{ label: 'Jira', icon: 'jira' }, { label: 'Figma', icon: 'figma' }, { label: 'Files', icon: 'files' }, { label: 'Video', icon: 'video' }],
  badges: [], icon: 'sliders', dashed: false, entryPath: 'adhoc',
};
const SPRINT_ENTRY: Step = {
  group: 'ENTRY', title: 'Sprint Run',
  subtitle: 'Auto-triggered when sprint starts', resultText: 'Sprint started',
  pills: [{ label: 'Jira', icon: 'jira' }, { label: 'GitHub', icon: 'github' }],
  badges: [], icon: 'bolt', dashed: false, entryPath: 'sprint',
};

const SHARED_STEPS: Step[] = [
  { group: 'SESSION', title: 'In Progress', subtitle: 'Session active', resultText: 'Session active', pills: [], badges: [], icon: 'spinner', dashed: false },

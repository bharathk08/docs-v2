---
// ─────────────────────────────────────────────────────────────────────────────
//  <AskOverlay /> — unified Search + Ask command palette (centered).
//
//  Search-first, ask-on-demand:
//   • As the user types, live keyword results stream in from Pagefind. Selecting
//     one navigates straight to that doc — zero LLM cost.
//   • A sparkle "Ask Assistant" row at the bottom is the explicit opt-in to an
//     AI answer (SSE → /api/ask). The model is only called when the user clicks
//     it, which keeps token usage low.
//
//  Opened by ⌘K, the header search box (#ts-search-trigger) and the Ask button
//  (#ts-ask-btn). Mounted globally through Footer.astro.
// ─────────────────────────────────────────────────────────────────────────────
---

<div id="ts-ask-overlay" class="ts-pal-overlay" hidden>
  <div class="ts-pal-backdrop" data-pal-close></div>

  <div class="ts-pal" role="dialog" aria-modal="true" aria-label="Search documentation or ask the assistant">
    {/* Input row */}
    <div class="ts-pal-inputrow">
      <svg class="ts-pal-search-ic" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
      </svg>
      <input
        id="ts-pal-input"
        class="ts-pal-input"
        type="text"
        placeholder="Search or ask…"
        autocomplete="off"
        autocapitalize="off"
        spellcheck="false"
        aria-label="Search or ask"
      />
      <span class="ts-pal-askhint" id="ts-pal-askhint" hidden>
        Ask Assistant <kbd>⏎</kbd>
      </span>
    </div>

    {/* Body */}
    <div class="ts-pal-body" id="ts-pal-body">
      {/* Empty state — suggested questions */}
      <div class="ts-pal-suggest" id="ts-pal-suggest"></div>

      {/* Live keyword results + ask row */}
      <div class="ts-pal-results" id="ts-pal-results" hidden></div>

      {/* AI answer (opt-in) */}
      <div class="ts-pal-answer-wrap" id="ts-pal-answer" hidden></div>
    </div>

    {/* Footer keyboard hints */}
    <div class="ts-pal-foot">
      <span class="ts-pal-foot-grp"><kbd>↑</kbd><kbd>↓</kbd> Select</span>
      <span class="ts-pal-foot-grp"><kbd>⏎</kbd> Open</span>
      <span class="ts-pal-foot-grp ts-pal-foot-right"><kbd>esc</kbd> Close</span>
    </div>
  </div>
</div>

<script>
  // ── Suggested questions, per product (empty-state) ─────────────────────────
  const SUGGESTIONS: Record<string, string[]> = {
    suite: [
      'How do I create a test case?',
      'What is Auto-Healing and how does it work?',
      'How do I trigger a Test Plan via API?',
      'How does Atto generate tests from Jira stories?',
      'How do I set up test data profiles?',
    ],
    arcus: [
      'How do I create a test case?',
      'How do I create a test run?',
      'How do I invite users and assign roles?',
      'How do I set up custom fields?',
      'How do I configure notifications?',
    ],
  };

  const ASK_API_URL = '/api/ask';

  const overlay = document.getElementById('ts-ask-overlay');
  if (overlay) {
    if (overlay.parentElement !== document.body) document.body.appendChild(overlay);

    const input     = document.getElementById('ts-pal-input') as HTMLInputElement;
    const askhint   = document.getElementById('ts-pal-askhint')!;
    const suggestEl = document.getElementById('ts-pal-suggest')!;
    const resultsEl = document.getElementById('ts-pal-results')!;
    const answerEl  = document.getElementById('ts-pal-answer')!;

    const product = () =>
      document.documentElement.getAttribute('data-product') === 'arcus' ? 'arcus' : 'suite';

    // ── Open / close ─────────────────────────────────────────────────────────
    let lastFocus: HTMLElement | null = null;
    function open() {
      lastFocus = document.activeElement as HTMLElement;
      renderSuggestions();
      showView('suggest');
      input.value = '';
      askhint.hidden = true;
      overlay!.hidden = false;
      document.documentElement.style.overflow = 'hidden';
      requestAnimationFrame(() => overlay!.classList.add('ts-pal-vis'));
      setTimeout(() => input.focus(), 50);
    }
    function close() {
      overlay!.classList.remove('ts-pal-vis');
      document.documentElement.style.overflow = '';
      setTimeout(() => {
        overlay!.hidden = true;
        resultsEl.innerHTML = '';
        answerEl.innerHTML = '';
        input.value = '';
      }, 180);
      lastFocus?.focus?.();
    }
    function isOpen() { return !overlay!.hidden; }

    function showView(v: 'suggest' | 'results' | 'answer') {
      suggestEl.hidden = v !== 'suggest';
      resultsEl.hidden = v !== 'results';
      answerEl.hidden  = v !== 'answer';
    }

    // ── Triggers: ⌘K, search box, Ask button ───────────────────────────────
    document.addEventListener('click', (e) => {
      const t = e.target as HTMLElement;
      if (t.closest('#ts-ask-btn') || t.closest('#ts-search-trigger')) {
        e.preventDefault();
        isOpen() ? close() : open();
      } else if (t.closest('[data-pal-close]')) {
        close();
      }
    });
    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        isOpen() ? close() : open();
      } else if (e.key === 'Escape' && isOpen()) {
        close();
      }
    });

    // ── Empty-state suggestions ─────────────────────────────────────────────
    function renderSuggestions() {
      const list = SUGGESTIONS[product()] ?? SUGGESTIONS.suite;
      suggestEl.innerHTML =
        '<div class="ts-pal-sectlabel">Suggested questions</div>' +
        list.map((q) =>
          `<button type="button" class="ts-pal-item ts-pal-sugg" data-q="${escapeHtml(q)}">
             <span class="ts-pal-ic">${IC_SPARK}</span>
             <span class="ts-pal-it-title">${escapeHtml(q)}</span>
           </button>`
        ).join('');
      suggestEl.querySelectorAll<HTMLElement>('.ts-pal-sugg').forEach((b) => {
        b.addEventListener('click', () => { input.value = b.dataset.q || ''; onInput(); input.focus(); });
      });
    }

    // ── Input handling (debounced live search) ──────────────────────────────
    let debounce: number | undefined;
    input.addEventListener('input', () => {
      window.clearTimeout(debounce);
      debounce = window.setTimeout(onInput, 130);
    });
    function onInput() {
      const q = input.value.trim();
      askhint.hidden = q.length === 0;
      if (!q) { showView('suggest'); return; }
      runSearch(q);
    }

    // Keyboard navigation across rendered items
    let items: HTMLElement[] = [];
    let sel = -1;
    function collectItems() {
      items = Array.from(resultsEl.querySelectorAll<HTMLElement>('.ts-pal-item'));
      sel = -1;                       // nothing pre-selected → Enter asks the assistant
      paintSel();
    }
    function paintSel() {
      items.forEach((el, i) => el.classList.toggle('ts-pal-item--sel', i === sel));
      if (sel >= 0) items[sel]?.scrollIntoView({ block: 'nearest' });
      // The "Ask Assistant ⏎" hint applies only when no doc is highlighted.
      askhint.hidden = !(input.value.trim() && sel === -1 && answerEl.hidden !== false);
    }
    function move(d: number) {
      if (!items.length) return;
      sel = sel === -1 ? (d > 0 ? 0 : items.length - 1)
                       : (sel + d + items.length) % items.length;
      paintSel();
    }
    function activate() {
      const el = items[sel];
      const q = input.value.trim();
      if (!el) { if (q) runAsk(q); return; }
      if (el.dataset.action === 'ask') runAsk(q);
      else el.click();   // <a> → navigate
    }
    input.addEventListener('keydown', (e) => {
      if (answerEl.hidden === false) {                 // in answer view
        if (e.key === 'Enter') { e.preventDefault(); const q = input.value.trim(); if (q) runSearch(q); }
        return;
      }
      if (e.key === 'ArrowDown') { e.preventDefault(); move(1); }
      else if (e.key === 'ArrowUp') { e.preventDefault(); move(-1); }
      else if (e.key === 'Enter')  { e.preventDefault(); activate(); }
    });

    // ── Pagefind keyword search ─────────────────────────────────────────────
    let pf: any = null;
    let pfTried = false;
    async function loadPagefind() {
      if (pf || pfTried) return pf;
      pfTried = true;
      try {
        const pfUrl = '/docs/pagefind/pagefind.js';
        pf = await import(/* @vite-ignore */ pfUrl);
        await pf.options?.({ excerptLength: 18 });
      } catch { pf = null; }
      return pf;
    }

    // Humanize a doc URL into a short breadcrumb, e.g.
    // /docs/suite/test-cases/create/ → "Suite › Test cases"
    function crumbFromUrl(url: string): string {
      const segs = url.replace(/^https?:\/\/[^/]+/, '').split('/').filter(Boolean);
      const i = segs.indexOf('docs');
      const parts = (i >= 0 ? segs.slice(i + 1) : segs).slice(0, -1); // drop the leaf
      return parts
        .map((s) => s.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase()))
        .join(' › ');
    }

    let searchSeq = 0;
    async function runSearch(query: string) {
      const seq = ++searchSeq;
      showView('results');
      const engine = await loadPagefind();

      // Always-present ask row markup
      const askRow =
        '<div class="ts-pal-sectlabel">Ask Assistant</div>' +
        `<button type="button" class="ts-pal-item ts-pal-ask" data-action="ask">
           <span class="ts-pal-ic ts-pal-ic-spark">${IC_SPARK}</span>
           <span class="ts-pal-it-title">Can you tell me about ${escapeHtml(query)}?</span>
         </button>`;

      if (!engine) {
        resultsEl.innerHTML =
          `<div class="ts-pal-note">Keyword search needs the built site — run <code>npm run build</code> or use the deployed docs. You can still ask the assistant.</div>` +
          askRow;
        collectItems();
        return;
      }

      const prefix = `/docs/${product()}/`;
      const search = await engine.search(query);
      if (seq !== searchSeq) return;                  // a newer query superseded us
      const raw  = await Promise.all(search.results.slice(0, 12).map((r: any) => r.data()));
      if (seq !== searchSeq) return;

      // Flatten pages + their headings into a single ranked list (product-scoped)
      type Item = { type: 'page' | 'head'; title: string; url: string; crumb: string };
      const flat: Item[] = [];
      for (const d of raw) {
        const url = d.url || '';
        if (!url.includes(prefix)) continue;
        const pageTitle = d.meta?.title || url;
        flat.push({ type: 'page', title: pageTitle, url, crumb: crumbFromUrl(url) });
        for (const sub of (d.sub_results || [])) {
          if (sub.title && sub.title !== pageTitle) {
            flat.push({ type: 'head', title: sub.title, url: sub.url || url, crumb: pageTitle });
          }
        }
      }
      const top = flat.slice(0, 7);

      const list = top.length
        ? '<div class="ts-pal-sectlabel">Documentation</div>' +
          top.map((it) =>
            `<a class="ts-pal-item" data-action="open" href="${escapeHtml(it.url)}">
               <span class="ts-pal-ic">${it.type === 'head' ? IC_HASH : IC_DOC}</span>
               <span class="ts-pal-it-text">
                 <span class="ts-pal-it-title">${escapeHtml(it.title)}</span>
                 ${it.crumb ? `<span class="ts-pal-it-crumb">${escapeHtml(it.crumb)}</span>` : ''}
               </span>
             </a>`
          ).join('')
        : `<div class="ts-pal-note">No matching docs in ${product()}. Ask the assistant for an answer.</div>`;

      resultsEl.innerHTML = list + askRow;
      // hover selects; the ask row needs an explicit click handler (the doc rows
      // are <a> and navigate natively)
      resultsEl.querySelectorAll<HTMLElement>('.ts-pal-item').forEach((el, i) => {
        el.addEventListener('mousemove', () => { sel = i; paintSel(); });
        if (el.dataset.action === 'ask') {
          el.addEventListener('click', (e) => { e.preventDefault(); runAsk(input.value.trim()); });
        }
      });
      collectItems();
    }

    // ── AI answer via SSE (opt-in) ───────────────────────────────────────────
    async function runAsk(query: string) {
      showView('answer');
      askhint.hidden = true;
      answerEl.innerHTML = `
        <button type="button" class="ts-pal-back" id="ts-pal-back">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          Back to results
        </button>
        <div class="ts-pal-q">${escapeHtml(query)}</div>
        <div class="ts-ask-thinking" id="ts-ask-thinking">
          <span class="ts-ask-spinner"></span>
          <span id="ts-ask-status-text">Finding relevant docs…</span>
        </div>
        <div class="ts-ask-answer" id="ts-ask-answer"></div>
        <div class="ts-ask-sources" id="ts-ask-sources" hidden></div>
      `;
      document.getElementById('ts-pal-back')!
        .addEventListener('click', () => { const q = input.value.trim(); q ? runSearch(q) : showView('suggest'); input.focus(); });

      const thinkingEl = document.getElementById('ts-ask-thinking')!;
      const statusEl   = document.getElementById('ts-ask-status-text')!;
      const ansEl      = document.getElementById('ts-ask-answer')!;
      const sourcesEl  = document.getElementById('ts-ask-sources')!;
      let   answerMd   = '';

      try {
        const resp = await fetch(ASK_API_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ question: query, product: product() }),
        });
        if (!resp.ok) throw new Error(`API responded ${resp.status}`);

        const reader  = resp.body!.getReader();
        const decoder = new TextDecoder();
        let buf = '', evt = '', data = '';

        while (true) {
          const { done, value } = await reader.read();
          if (done) break;
          buf += decoder.decode(value, { stream: true });
          const lines = buf.split('\n');
          buf = lines.pop() ?? '';
          for (const line of lines) {
            if (line.startsWith('event: ')) evt = line.slice(7).trim();
            else if (line.startsWith('data: ')) data = line.slice(6);
            else if (line === '' && evt) {
              try {
                const payload = JSON.parse(data);
                if (evt === 'status') {
                  statusEl.textContent = payload.text;
                } else if (evt === 'delta') {
                  thinkingEl.hidden = true;
                  answerMd += payload.text;
                  ansEl.innerHTML = renderMarkdown(answerMd);
                } else if (evt === 'sources') {
                  const srcs = payload as { url: string; title: string }[];
                  if (srcs.length) {
                    sourcesEl.innerHTML =
                      '<div class="ts-ask-sources-head">Related documentation</div>' +
                      srcs.map((s) =>
                        `<a class="ts-pal-item" href="${escapeHtml(s.url)}">
                           <span class="ts-pal-ic">${IC_DOC}</span>
                           <span class="ts-pal-it-title">${escapeHtml(s.title || s.url)}</span>
                         </a>`
                      ).join('');
                    sourcesEl.hidden = false;
                  }
                } else if (evt === 'error') {
                  throw new Error(payload.message);
                }
              } catch { /* skip malformed SSE line */ }
              evt = ''; data = '';
            }
          }
        }
        thinkingEl.hidden = true;
      } catch (err: any) {
        thinkingEl.hidden = true;
        ansEl.innerHTML =
          `<div class="ts-pal-note">The assistant is unavailable right now (${escapeHtml(err.message)}). Try the keyword results above.</div>`;
      }
    }

    // ── Markdown renderer for the AI answer ──────────────────────────────────
    function escHtml(s: string): string {
      return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }
    function inlineMd(text: string): string {
      return text.split(/(`[^`]+`)/).map((seg) => {
        if (seg.length > 1 && seg[0] === '`' && seg[seg.length - 1] === '`') {
          return `<code>${seg.slice(1, -1)}</code>`;
        }
        return seg
          .replace(/\[([^\]]+)\]\(([^)\s]+)\)/g, (_m, label, url) =>
            /^(https?:\/\/|\/|#|mailto:)/i.test(url)
              ? `<a href="${url}" target="_blank" rel="noopener noreferrer">${label}</a>`
              : label)
          .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
          .replace(/\*([^*]+)\*/g, '<em>$1</em>')
          .replace(/\[(\d+)\]/g, '<sup class="ts-ask-cite">[$1]</sup>');
      }).join('');
    }
    function renderMarkdown(md: string): string {
      const lines = md.replace(/\r\n/g, '\n').split('\n');
      let html = '', i = 0;
      let para: string[] = [];
      const flush = () => { if (para.length) { html += `<p>${inlineMd(escHtml(para.join(' ')))}</p>`; para = []; } };
      while (i < lines.length) {
        const line = lines[i];
        const fence = line.match(/^```(\w*)\s*$/);
        if (fence) { flush(); const buf: string[] = []; i++;
          while (i < lines.length && !/^```\s*$/.test(lines[i])) { buf.push(lines[i]); i++; }
          i++; html += `<pre class="ts-ask-pre"><code>${escHtml(buf.join('\n'))}</code></pre>`; continue; }
        const h = line.match(/^(#{1,6})\s+(.*)$/);
        if (h) { flush(); const lvl = h[1].length; html += `<h${lvl}>${inlineMd(escHtml(h[2].trim()))}</h${lvl}>`; i++; continue; }
        if (/^>\s?/.test(line)) { flush(); const buf: string[] = [];
          while (i < lines.length && /^>\s?/.test(lines[i])) { buf.push(lines[i].replace(/^>\s?/, '')); i++; }
          html += `<blockquote>${inlineMd(escHtml(buf.join(' ')))}</blockquote>`; continue; }
        if (/^\s*[-*+]\s+/.test(line)) { flush(); html += '<ul>';
          while (i < lines.length && /^\s*[-*+]\s+/.test(lines[i])) { html += `<li>${inlineMd(escHtml(lines[i].replace(/^\s*[-*+]\s+/, '')))}</li>`; i++; }
          html += '</ul>'; continue; }
        if (/^\s*\d+\.\s+/.test(line)) { flush(); html += '<ol>';
          while (i < lines.length && /^\s*\d+\.\s+/.test(lines[i])) { html += `<li>${inlineMd(escHtml(lines[i].replace(/^\s*\d+\.\s+/, '')))}</li>`; i++; }
          html += '</ol>'; continue; }
        if (/^\s*([-*_])(\s*\1){2,}\s*$/.test(line)) { flush(); html += '<hr>'; i++; continue; }
        if (line.trim() === '') { flush(); i++; continue; }
        para.push(line.trim()); i++;
      }
      flush();
      return html;
    }

    function escapeHtml(s: string): string {
      return s.replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c] as string));
    }

    // ── Inline icons ─────────────────────────────────────────────────────────
    const IC_DOC =
      '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg>';
    const IC_HASH =
      '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="9" x2="20" y2="9"/><line x1="4" y1="15" x2="20" y2="15"/><line x1="10" y1="3" x2="8" y2="21"/><line x1="16" y1="3" x2="14" y2="21"/></svg>';
    const IC_SPARK =
      '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l1.9 5.2L19 9l-5.1 1.8L12 16l-1.9-5.2L5 9l5.1-1.8z"/><path d="M19 14l.8 2.2L22 17l-2.2.8L19 20l-.8-2.2L16 17l2.2-.8z"/></svg>';
  }
</script>

<style is:global>
  /* All result/answer markup is injected via JS, so styling is global with a
     unique ts-pal-* / ts-ask-* prefix. */

  .ts-pal-overlay[hidden] { display: none; }
  .ts-pal-overlay {
    position: fixed; inset: 0; z-index: 9999;
  }
  .ts-pal-backdrop {
    position: absolute; inset: 0;
    background: rgba(9, 30, 66, 0.30);
    -webkit-backdrop-filter: blur(2px); backdrop-filter: blur(2px);
    opacity: 0; transition: opacity 0.18s ease;
  }
  .ts-pal-overlay.ts-pal-vis .ts-pal-backdrop { opacity: 1; }

  .ts-pal {
    position: absolute;
    top: 11vh; left: 50%;
    transform: translateX(-50%) translateY(-8px) scale(0.98);
    width: min(640px, 92vw);
    max-height: 72vh;
    background: #fff;
    border: 1px solid var(--ts-border);
    border-radius: 14px;
    box-shadow: 0 24px 64px rgba(9, 30, 66, 0.24);
    display: flex; flex-direction: column;
    overflow: hidden;
    opacity: 0;
    transition: opacity 0.18s ease, transform 0.18s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .ts-pal-overlay.ts-pal-vis .ts-pal {
    opacity: 1;
    transform: translateX(-50%) translateY(0) scale(1);
  }

  /* Input row */
  .ts-pal-inputrow {
    display: flex; align-items: center; gap: 12px;
    padding: 16px 18px;
    border-bottom: 1px solid var(--ts-border);
    flex-shrink: 0;
  }
  .ts-pal-search-ic { color: var(--ts-text-tertiary); flex-shrink: 0; }
  .ts-pal-input {
    flex: 1; min-width: 0;
    border: none; outline: none; background: transparent;
    font-family: inherit; font-size: 17px; color: var(--ts-text-primary);
    line-height: 1.4;
  }
  .ts-pal-input::placeholder { color: var(--ts-text-tertiary); }
  .ts-pal-askhint {
    display: inline-flex; align-items: center; gap: 6px;
    flex-shrink: 0;
    padding: 5px 9px; border-radius: 8px;
    background: var(--ts-accent-low);
    font-size: 12.5px; font-weight: 600; color: var(--ts-accent-text);
    white-space: nowrap;
  }
  .ts-pal-askhint[hidden] { display: none; }
  .ts-pal-askhint kbd {
    font-family: inherit; font-size: 11px; font-weight: 700;
    background: #fff; border: 1px solid var(--ts-border-strong);
    border-radius: 4px; padding: 0 4px; color: var(--ts-text-secondary);
  }

  /* Body */
  .ts-pal-body { flex: 1; overflow-y: auto; padding: 8px; }
  .ts-pal-suggest[hidden], .ts-pal-results[hidden], .ts-pal-answer-wrap[hidden] { display: none; }

  .ts-pal-sectlabel {
    font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em;
    color: var(--ts-text-tertiary);
    padding: 12px 10px 6px;
  }

  /* List item (shared: results, headings, suggestions, ask row, sources) */
  .ts-pal-item {
    display: flex; align-items: center; gap: 12px;
    width: 100%;
    padding: 10px 12px;
    border: none; background: transparent;
    border-radius: 9px;
    text-align: left; text-decoration: none;
    font-family: inherit; cursor: pointer;
    color: var(--ts-text-primary);
  }
  .ts-pal-item--sel { background: var(--ts-hover-row); }
  .ts-pal-ic {
    flex-shrink: 0; width: 22px; height: 22px;
    display: inline-flex; align-items: center; justify-content: center;
    color: var(--ts-text-tertiary);
  }

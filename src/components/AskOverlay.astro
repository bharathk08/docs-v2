---
// ─────────────────────────────────────────────────────────────────────────────
//  <AskOverlay /> — the "Ask Assistant" right-side drawer.
//
//  Calls /api/ask (SSE) → streams a Claude-generated answer → shows source links.
//  Falls back to Pagefind keyword search if the API is unavailable.
//  Mounted globally through Footer.astro.
// ─────────────────────────────────────────────────────────────────────────────
---

<div id="ts-ask-overlay" class="ts-ask-overlay" hidden>
  <div class="ts-ask-backdrop" data-ask-close></div>

  <aside class="ts-ask-panel" role="dialog" aria-modal="true" aria-label="Ask Assistant">
    <header class="ts-ask-head">
      <span class="ts-ask-head-icon" aria-hidden="true">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="6" width="18" height="14" rx="3.5"/>
          <line x1="12" y1="3" x2="12" y2="6"/><circle cx="12" cy="2.5" r="1"/>
          <rect x="1" y="10" width="2" height="5" rx="1"/><rect x="21" y="10" width="2" height="5" rx="1"/>
          <circle cx="9" cy="12" r="1.6" fill="#fff" stroke="none"/><circle cx="15" cy="12" r="1.6" fill="#fff" stroke="none"/>
          <path d="M9 16.5 Q12 18.5 15 16.5" stroke-width="1.4"/>
        </svg>
      </span>
      <div class="ts-ask-head-text">
        <div class="ts-ask-head-title">Ask Assistant</div>
        <div class="ts-ask-head-sub">Answers from Testsigma docs</div>
      </div>
      <button class="ts-ask-close" data-ask-close aria-label="Close Ask Assistant">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
      </button>
    </header>

    <div class="ts-ask-body" id="ts-ask-body">
      {/* Default view: hero + suggested questions */}
      <div class="ts-ask-intro" id="ts-ask-intro">
        <div class="ts-ask-hero">
          <svg class="ts-ask-hero-icon" width="62" height="62" viewBox="0 0 48 48" fill="none" aria-hidden="true">
            <circle cx="20" cy="20" r="12.5" stroke="var(--ts-text-primary)" stroke-width="2.4"/>
            <line x1="29.5" y1="29.5" x2="40" y2="40" stroke="var(--ts-text-primary)" stroke-width="2.4" stroke-linecap="round"/>
            <path d="M37 6 l1.6 4.4 4.4 1.6 -4.4 1.6 -1.6 4.4 -1.6 -4.4 -4.4 -1.6 4.4 -1.6 z" fill="#5b23d6"/>
          </svg>
          <div class="ts-ask-hero-title">Search documentation. <span class="ts-ask-hero-accent">Get answers.</span></div>
          <div class="ts-ask-poweredby">
            <span>POWERED BY</span>
            <img src="/docs/testsigma-logo.svg" alt="Testsigma" height="16" />
          </div>
        </div>
        <div class="ts-ask-suggestions" id="ts-ask-suggestions"></div>
      </div>

      {/* Search results view */}
      <div class="ts-ask-results" id="ts-ask-results" hidden></div>
    </div>

    <footer class="ts-ask-foot">
      <form class="ts-ask-inputwrap" id="ts-ask-form">
        <textarea
          class="ts-ask-input"
          id="ts-ask-input"
          rows="1"
          placeholder="Ask anything about the docs…"
          autocomplete="off"
        ></textarea>
        <div class="ts-ask-input-row">
          <span class="ts-ask-context">
            <span class="ts-ask-context-icon" aria-hidden="true">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="6" width="18" height="14" rx="3.5"/><line x1="12" y1="3" x2="12" y2="6"/><circle cx="12" cy="2.5" r="1"/>
                <circle cx="9" cy="12" r="1.6" fill="#fff" stroke="none"/><circle cx="15" cy="12" r="1.6" fill="#fff" stroke="none"/><path d="M9 16.5 Q12 18.5 15 16.5" stroke-width="1.4"/>
              </svg>
            </span>
            <strong>AI</strong>
            <span class="ts-ask-context-sub">Based on your context</span>
          </span>
          <button type="submit" class="ts-ask-send">Send</button>
        </div>
      </form>
    </footer>
  </aside>
</div>

<script>
  // ── Suggested questions, per product ──────────────────────────────────────
  const SUGGESTIONS: Record<string, string[]> = {
    suite: [
      'How do I create a test case?',
      'What is Auto-Healing and how does it work?',
      'How do I trigger a Test Plan via API?',
      'How does Atto generate tests from Jira stories?',
      'How do I set up test data profiles?',
    ],
    arcus: [
      'How do I create a test case?',
      'How do I create a test run?',
      'How do I invite users and assign roles?',
      'How do I set up custom fields?',
      'How do I configure notifications?',
    ],
  };

  // Change this to '/.netlify/functions/ask' for Netlify deployments,
  // or to the full URL when hosting on testsigma.com.
  const ASK_API_URL = '/api/ask';

  const overlay = document.getElementById('ts-ask-overlay');
  if (overlay) {
    if (overlay.parentElement !== document.body) document.body.appendChild(overlay);

    const intro   = document.getElementById('ts-ask-intro')!;
    const results = document.getElementById('ts-ask-results')!;
    const sugWrap = document.getElementById('ts-ask-suggestions')!;
    const form    = document.getElementById('ts-ask-form') as HTMLFormElement;
    const input   = document.getElementById('ts-ask-input') as HTMLTextAreaElement;

    const product = () =>
      document.documentElement.getAttribute('data-product') === 'arcus' ? 'arcus' : 'suite';

    function renderSuggestions() {
      const list = SUGGESTIONS[product()] ?? SUGGESTIONS.suite;
      sugWrap.innerHTML = '';
      for (const q of list) {
        const b = document.createElement('button');
        b.type = 'button';
        b.className = 'ts-ask-suggestion';
        b.textContent = q;
        b.addEventListener('click', () => { input.value = q; ask(q); });
        sugWrap.appendChild(b);
      }
    }

    let lastFocus: HTMLElement | null = null;
    function open() {
      lastFocus = document.activeElement as HTMLElement;
      renderSuggestions();
      overlay!.hidden = false;
      document.documentElement.style.overflow = 'hidden';
      requestAnimationFrame(() => overlay!.classList.add('ts-ask-open'));
      setTimeout(() => input.focus(), 60);
    }
    function close() {
      overlay!.classList.remove('ts-ask-open');
      document.documentElement.style.overflow = '';
      setTimeout(() => {
        overlay!.hidden = true;
        results.hidden = true;
        results.innerHTML = '';
        intro.hidden = false;
        input.value = '';
      }, 220);
      lastFocus?.focus?.();
    }
    function showResults() { intro.hidden = true; results.hidden = false; }
    function resetToIntro() {
      results.hidden = true;
      results.innerHTML = '';
      intro.hidden = false;
      input.value = '';
      input.focus();
    }

    document.addEventListener('click', (e) => {
      const t = e.target as HTMLElement;
      if (t.closest('#ts-ask-btn'))        { e.preventDefault(); open(); }
      else if (t.closest('[data-ask-close]')) { close(); }
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !overlay!.hidden) close();
    });
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const q = input.value.trim();
      if (q) ask(q);
    });
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); form.requestSubmit(); }
    });

    // Briefly flip an inline endpoint/URL chip to a "copied" check state.
    function flashCopied(chip: HTMLElement) {
      const ic = chip.querySelector('.ts-ask-ic-btn');
      if (chip.classList.contains('is-copied')) return;   // ignore rapid re-clicks mid-flash
      chip.classList.add('is-copied');
      chip.setAttribute('title', 'Copied');
      const prev = ic ? ic.innerHTML : '';
      if (ic) ic.innerHTML = IC_CHECK;
      setTimeout(() => {
        chip.classList.remove('is-copied');
        chip.setAttribute('title', 'Copy');
        if (ic) ic.innerHTML = prev;
      }, 1300);
    }

    function copyInlineChip(chip: HTMLElement) {
      const txt = chip.querySelector('.ts-ask-ic-txt')?.textContent || chip.textContent || '';
      navigator.clipboard?.writeText(txt.trim());
      flashCopied(chip);
    }

    // Copy affordances (delegated — the answer HTML is rebuilt on every stream
    // delta, so a listener on the stable container survives). Handles both the
    // code-block copy button and inline endpoint/URL chips.
    results.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;

      const chip = target.closest('.ts-ask-inline-copy') as HTMLElement | null;
      if (chip) { copyInlineChip(chip); return; }

      const btn = target.closest('.ts-ask-copy') as HTMLElement | null;
      if (!btn) return;
      const codeEl = btn.closest('.ts-ask-codeblock')?.querySelector('code');
      if (!codeEl) return;
      navigator.clipboard?.writeText(codeEl.textContent || '');
      const lbl = btn.querySelector('.ts-ask-copy-text');
      if (lbl) { const prev = lbl.textContent; lbl.textContent = 'Copied'; setTimeout(() => { lbl.textContent = prev || 'Copy'; }, 1300); }
    });

    // Keyboard activation for inline copy chips (role="button").
    results.addEventListener('keydown', (e) => {
      if (e.key !== 'Enter' && e.key !== ' ') return;
      const chip = (e.target as HTMLElement).closest('.ts-ask-inline-copy') as HTMLElement | null;
      if (!chip) return;
      e.preventDefault();
      copyInlineChip(chip);
    });

    // ── AI answer via SSE ────────────────────────────────────────────────────
    async function ask(query: string) {
      showResults();
      input.value = '';   // clear the box once the question is sent
      results.innerHTML = `
        <div class="ts-ask-thinking" id="ts-ask-thinking">
          <span class="ts-ask-spinner"></span>
          <span id="ts-ask-status-text">Finding relevant docs…</span>
        </div>
        <div class="ts-ask-answer" id="ts-ask-answer"></div>
        <div class="ts-ask-sources" id="ts-ask-sources" hidden></div>
      `;

      const thinkingEl = document.getElementById('ts-ask-thinking')!;
      const statusEl   = document.getElementById('ts-ask-status-text')!;
      const answerEl   = document.getElementById('ts-ask-answer')!;
      const sourcesEl  = document.getElementById('ts-ask-sources')!;
      let   answerMd   = '';

      try {
        const resp = await fetch(ASK_API_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ question: query, product: product() }),
        });

        if (!resp.ok) throw new Error(`API responded ${resp.status}`);

        const reader  = resp.body!.getReader();
        const decoder = new TextDecoder();
        let   buf     = '';
        let   evt     = '';
        let   data    = '';

        while (true) {
          const { done, value } = await reader.read();
          if (done) break;
          buf += decoder.decode(value, { stream: true });

          const lines = buf.split('\n');
          buf = lines.pop() ?? '';

          for (const line of lines) {
            if (line.startsWith('event: ')) {
              evt = line.slice(7).trim();
            } else if (line.startsWith('data: ')) {
              data = line.slice(6);
            } else if (line === '' && evt) {
              try {
                const payload = JSON.parse(data);
                if (evt === 'status') {
                  statusEl.textContent = payload.text;
                } else if (evt === 'delta') {
                  thinkingEl.hidden = true;
                  answerMd += payload.text;
                  answerEl.innerHTML = renderMarkdown(answerMd);
                } else if (evt === 'sources') {
                  const srcs = payload as { url: string; title: string }[];
                  if (srcs.length) {
                    sourcesEl.innerHTML =
                      '<div class="ts-ask-sources-head">Related documentation</div>' +
                      srcs.map(s =>
                        `<a class="ts-ask-result" href="${escapeHtml(s.url)}">
                          <div class="ts-ask-result-title">${escapeHtml(s.title || s.url)}</div>
                        </a>`
                      ).join('');
                    sourcesEl.hidden = false;
                  }
                } else if (evt === 'error') {
                  throw new Error(payload.message);
                }
              } catch (parseErr) { /* malformed SSE line — skip */ }
              evt = ''; data = '';
            }
          }
        }

        // Stream finished — make sure the "thinking" indicator is gone
        thinkingEl.hidden = true;

        // "Ask another question" link at the bottom
        const resetBtn = document.createElement('button');
        resetBtn.type = 'button';
        resetBtn.className = 'ts-ask-reset';
        resetBtn.textContent = 'Ask another question';
        resetBtn.addEventListener('click', resetToIntro);
        results.appendChild(resetBtn);

      } catch (err: any) {
        console.warn('Ask Assistant API unavailable, falling back to keyword search:', err.message);
        await keywordSearch(query);
      }
    }

    // ── Markdown renderer for the answer ─────────────────────────────────────
    // Block-level parser (headings, lists, code blocks, quotes) + inline
    // formatting. XSS-safe: all text is HTML-escaped before any tags are added,
    // and link hrefs are scheme-validated.
    function escHtml(s: string): string {
      return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }

    // Inline formatting — `text` MUST already be HTML-escaped.
    function inlineMd(text: string): string {
      // Split out inline-code spans; format only the non-code segments so
      // markdown inside backticks is left verbatim.
      return text.split(/(`[^`]+`)/).map((seg) => {
        if (seg.length > 1 && seg[0] === '`' && seg[seg.length - 1] === '`') {
          const inner = seg.slice(1, -1);
          // Endpoints and URLs get a click-to-copy affordance. `inner` is already
          // HTML-escaped, so &amp; etc. are decoded back to real chars on copy
          // (we copy the text node's textContent, not this escaped markup).
          const t = inner.trim();
          const copyable =
            /^https?:\/\/\S+$/.test(t) ||                                   // full URL
            /^\/[A-Za-z0-9_~%.\/:{}()[\]@&;=?+#-]*$/.test(t) ||             // /endpoint path
            /^(GET|POST|PUT|PATCH|DELETE|HEAD|OPTIONS)\s+\/\S+$/i.test(t);  // METHOD /path
          if (copyable) {
            return '<code class="ts-ask-inline-copy" role="button" tabindex="0" title="Copy">' +
                     `<span class="ts-ask-ic-txt">${inner}</span>` +
                     `<span class="ts-ask-ic-btn" aria-hidden="true">${IC_COPY}</span>` +
                   '</code>';
          }
          return `<code>${inner}</code>`;
        }
        return seg
          // Links [label](url) — only safe schemes, else fall back to the label
          .replace(/\[([^\]]+)\]\(([^)\s]+)\)/g, (_m, label, url) =>
            /^(https?:\/\/|\/|#|mailto:)/i.test(url)
              ? `<a href="${url}" target="_blank" rel="noopener noreferrer">${label}</a>`
              : label)
          .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
          .replace(/\*([^*]+)\*/g, '<em>$1</em>')
          .replace(/\[(\d+)\]/g, '<sup class="ts-ask-cite">[$1]</sup>');
      }).join('');
    }

    function renderMarkdown(md: string): string {
      const lines = md.replace(/\r\n/g, '\n').split('\n');
      let html = '';
      let para: string[] = [];
      let i = 0;

      const flush = () => {
        if (para.length) { html += `<p>${inlineMd(escHtml(para.join(' ')))}</p>`; para = []; }
      };

      while (i < lines.length) {
        const line = lines[i];

        const fence = line.match(/^```(\w*)\s*$/);
        if (fence) {                                   // fenced code block
          flush();
          const lang = (fence[1] || '').toLowerCase();
          const buf: string[] = [];
          i++;
          while (i < lines.length && !/^```\s*$/.test(lines[i])) { buf.push(lines[i]); i++; }
          i++;                                         // skip closing fence (or run to EOF)
          const code = buf.join('\n');
          html +=
            '<div class="ts-ask-codeblock">' +
              '<div class="ts-ask-code-head">' +
                `<span class="ts-ask-code-lang">${escHtml(langLabel(lang))}</span>` +
                `<button type="button" class="ts-ask-copy" aria-label="Copy code">${IC_COPY}<span class="ts-ask-copy-text">Copy</span></button>` +
              '</div>' +
              `<pre class="ts-ask-pre"><code>${highlightCode(code, lang)}</code></pre>` +
            '</div>';
          continue;
        }

        const h = line.match(/^(#{1,6})\s+(.*)$/);
        if (h) {                                       // heading
          flush();
          const lvl = h[1].length;
          html += `<h${lvl}>${inlineMd(escHtml(h[2].trim()))}</h${lvl}>`;
          i++; continue;
        }

        // GFM table: a header row followed by a |---|---| separator row.
        const isTableSep = (s: string) =>
          /^\s*\|?\s*:?-{1,}:?\s*(\|\s*:?-{1,}:?\s*)*\|?\s*$/.test(s);
        const splitRow = (s: string) =>
          s.trim().replace(/^\|/, '').replace(/\|\s*$/, '').split('|').map((c) => c.trim());
        if (line.includes('|') && i + 1 < lines.length && isTableSep(lines[i + 1])) {
          flush();
          const header = splitRow(line);
          i += 2;                                      // skip header + separator
          const rows: string[][] = [];
          while (i < lines.length && lines[i].trim() !== '' && lines[i].includes('|')) {
            rows.push(splitRow(lines[i])); i++;
          }
          let t = '<div class="ts-ask-tablewrap"><table class="ts-ask-table"><thead><tr>';
          for (const c of header) t += `<th>${inlineMd(escHtml(c))}</th>`;
          t += '</tr></thead><tbody>';
          for (const r of rows) {
            t += '<tr>';
            for (let c = 0; c < header.length; c++) t += `<td>${inlineMd(escHtml(r[c] || ''))}</td>`;
            t += '</tr>';
          }
          t += '</tbody></table></div>';
          html += t;
          continue;
        }

        if (/^>\s?/.test(line)) {                      // blockquote
          flush();
          const buf: string[] = [];
          while (i < lines.length && /^>\s?/.test(lines[i])) { buf.push(lines[i].replace(/^>\s?/, '')); i++; }
          html += `<blockquote>${inlineMd(escHtml(buf.join(' ')))}</blockquote>`;
          continue;
        }

        if (/^\s*[-*+]\s+/.test(line)) {               // unordered list
          flush();
          html += '<ul>';
          while (i < lines.length && /^\s*[-*+]\s+/.test(lines[i])) {
            html += `<li>${inlineMd(escHtml(lines[i].replace(/^\s*[-*+]\s+/, '')))}</li>`; i++;
          }
          html += '</ul>';
          continue;
        }

        if (/^\s*\d+\.\s+/.test(line)) {               // ordered list
          flush();
          html += '<ol>';
          while (i < lines.length && /^\s*\d+\.\s+/.test(lines[i])) {
            html += `<li>${inlineMd(escHtml(lines[i].replace(/^\s*\d+\.\s+/, '')))}</li>`; i++;
          }
          html += '</ol>';
          continue;
        }

        if (/^\s*([-*_])(\s*\1){2,}\s*$/.test(line)) { // horizontal rule
          flush(); html += '<hr>'; i++; continue;
        }

        if (line.trim() === '') { flush(); i++; continue; }

        para.push(line.trim());                        // normal paragraph text
        i++;
      }
      flush();
      return html;
    }

    // ── Pagefind keyword search (fallback) ───────────────────────────────────
    let pf: any = null;
    let pfTried = false;
    async function loadPagefind() {
      if (pf || pfTried) return pf;
      pfTried = true;
      try {
        // Indirect through a variable so Rollup leaves it as a runtime import
        // (Pagefind only exists in the built site, not in the source tree).
        const pfUrl = '/docs/pagefind/pagefind.js';
        pf = await import(/* @vite-ignore */ pfUrl);
        await pf.options?.({ excerptLength: 24 });
      } catch { pf = null; }
      return pf;
    }

    async function keywordSearch(query: string) {
      results.innerHTML = '<div class="ts-ask-status">Searching the docs…</div>';
      const engine = await loadPagefind();
      if (!engine) {
        results.innerHTML =
          '<div class="ts-ask-status">Search requires a built site. Run <code>npm run build</code> first, or use the deployed site.</div>';
        return;
      }
      const prefix = `/docs/${product()}/`;
      const search = await engine.search(query);
      const raw    = await Promise.all(search.results.slice(0, 12).map((r: any) => r.data()));
      const hits   = raw.filter((d: any) => (d.url || '').includes(prefix)).slice(0, 6);

      if (!hits.length) {
        results.innerHTML = `<div class="ts-ask-status">No results for “${escapeHtml(query)}” in ${product()} docs.</div>`;
        return;
      }
      results.innerHTML =
        `<div class="ts-ask-results-head">Results for “${escapeHtml(query)}”</div>` +
        hits.map((d: any) =>
          `<a class="ts-ask-result" href="${d.url}">
            <div class="ts-ask-result-title">${escapeHtml(d.meta?.title || d.url)}</div>
            <div class="ts-ask-result-excerpt">${d.excerpt || ''}</div>
          </a>`
        ).join('');
    }

    function escapeHtml(s: string): string {
      return s.replace(/[&<>"]/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c] as string));
    }

    // ── Code block: language label + lightweight syntax highlighting ─────────
    const IC_COPY =
      '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>';
    const IC_CHECK =
      '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>';

    const LANG_LABELS: Record<string, string> = {
      bash: 'Bash', sh: 'Shell', shell: 'Shell', console: 'Shell', zsh: 'Shell',
      powershell: 'PowerShell', ps: 'PowerShell', ps1: 'PowerShell',
      cmd: 'CMD', bat: 'Batch', json: 'JSON', yaml: 'YAML', yml: 'YAML',
      js: 'JavaScript', javascript: 'JavaScript', ts: 'TypeScript', typescript: 'TypeScript',
      java: 'Java', python: 'Python', py: 'Python', http: 'HTTP', xml: 'XML', html: 'HTML', sql: 'SQL',
    };
    function langLabel(lang: string): string {
      return LANG_LABELS[lang] || (lang ? lang.toUpperCase() : 'Code');
    }

    // Tiny, dependency-free highlighter. Walks the raw code with a prioritized
    // list of sticky regexes so tokens never overlap; everything else is escaped
    // verbatim. Token <span> classes are styled in the stylesheet below.
    function tokenize(code: string, specs: [RegExp, string][]): string {
      let out = '', i = 0;
      while (i < code.length) {
        let matched = false;
        for (const [re, cls] of specs) {
          re.lastIndex = i;
          const m = re.exec(code);
          if (m && m.index === i && m[0].length) {
            out += cls ? `<span class="hl-${cls}">${escHtml(m[0])}</span>` : escHtml(m[0]);
            i += m[0].length; matched = true; break;
          }
        }
        if (!matched) { out += escHtml(code[i]); i++; }
      }
      return out;
    }
    function highlightCode(code: string, lang: string): string {
      const SHELL: [RegExp, string][] = [
        [/#[^\n]*/y, 'comment'],
        [/"(?:[^"\\]|\\.)*"/y, 'string'],
        [/'(?:[^'\\]|\\.)*'/y, 'string'],
        [/https?:\/\/[^\s'"`)]+/y, 'url'],
        [/(?:--?[A-Za-z][\w-]*)/y, 'flag'],
        [/[|&;><]+/y, 'oper'],
        [/\b\d+(?:\.\d+)*\b/y, 'num'],
      ];
      const JSON_: [RegExp, string][] = [
        [/"(?:[^"\\]|\\.)*"(?=\s*:)/y, 'key'],
        [/"(?:[^"\\]|\\.)*"/y, 'string'],
        [/\b(?:true|false|null)\b/y, 'kw'],
        [/-?\d+(?:\.\d+)?(?:[eE][+-]?\d+)?/y, 'num'],
      ];
      const GENERIC: [RegExp, string][] = [
        [/\/\/[^\n]*/y, 'comment'],
        [/#[^\n]*/y, 'comment'],
        [/"(?:[^"\\]|\\.)*"/y, 'string'],
        [/'(?:[^'\\]|\\.)*'/y, 'string'],
        [/`(?:[^`\\]|\\.)*`/y, 'string'],
        [/https?:\/\/[^\s'"`)]+/y, 'url'],
        [/\b\d+(?:\.\d+)?\b/y, 'num'],
      ];
      if (['json'].includes(lang)) return tokenize(code, JSON_);
      if (['bash','sh','shell','console','zsh','powershell','ps','ps1','cmd','bat','yaml','yml','http'].includes(lang) || !lang)
        return tokenize(code, SHELL);
      return tokenize(code, GENERIC);
    }
  }
</script>


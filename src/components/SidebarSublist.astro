---
interface SidebarLink {
  type: 'link';
  label: string;
  href: string;
  isCurrent: boolean;
  badge?: { variant: string; class?: string; text: string } | undefined;
  attrs: Record<string, any>;
}
interface SidebarGroup {
  type: 'group';
  label: string;
  entries: SidebarEntry[];
  collapsed: boolean;
  badge?: { variant: string; class?: string; text: string } | undefined;
}
type SidebarEntry = SidebarLink | SidebarGroup;

interface Props {
  sublist: SidebarEntry[];
  nested?: boolean;
  depth?: number;
  api?: boolean;
  /** Render links with no leading icon/pill (used for the Changelog month list). */
  plain?: boolean;
}

const { sublist, nested, depth = 0, api, plain } = Astro.props;

function hasCurrentDescendant(entries: SidebarEntry[]): boolean {
  for (const e of entries) {
    if (e.type === 'link' && e.isCurrent) return true;
    if (e.type === 'group' && hasCurrentDescendant(e.entries)) return true;
  }
  return false;
}


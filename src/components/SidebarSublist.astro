function iconSvg(key: string): string {
  const paths = (ICONS[key] ?? ICONS.default).split('||');
  return paths.map((d) => `<path d="${d}" stroke-linecap="round" stroke-linejoin="round"/>`).join('');
}

// ── Label normalizer — converts raw folder slugs to readable names ────────────
// Known acronyms and overrides first; fallback to title-casing hyphenated slugs.
const LABEL_OVERRIDES: Record<string, string> = {
  'generative-ai':              'Generative AI',
  'ai-agents':                  'AI Agents',
  'ai':                         'AI',
  'api':                        'API',
  'rest-api':                   'REST API',
  'soap-api':                   'SOAP & REST API',
  'byok':                       'BYOK',
  'supported-llms':             'Supported LLMs',
  'nlps':                       'NLPs',
  'sdk':                        'SDK',
  'ios-apps':                   'iOS Apps',
  'ci-cd':                      'CI/CD',
  'on-prem':                    'On-Premise',
  'sap-automation':             'SAP Automation',
  'restapi':                    'REST API',
  'create-steps-restapi':       'Create Steps (REST API)',
  'actions-and-options-manual':   'Actions & Options (Manual)',
  'actions-and-options-recorder': 'Actions & Options (Recorder)',
  'imports-and-exports':        'Imports & Exports',
  'open-source-dev-environment-setup': 'Dev Environment Setup',
};

const WORD_CAPS: Record<string, string> = {
  ai: 'AI', api: 'API', sdk: 'SDK', sap: 'SAP', ios: 'iOS',
  nlp: 'NLP', nlps: 'NLPs', llm: 'LLM', llms: 'LLMs',
  byok: 'BYOK', ci: 'CI', cd: 'CD', rest: 'REST', soap: 'SOAP',
  faqs: 'FAQs', faq: 'FAQ', ui: 'UI', url: 'URL',
};

function formatLabel(label: string): string {
  // If it already has uppercase letters or spaces it came from explicit config — keep it
  if (/[A-Z]/.test(label) || label.includes(' ')) return label;
  // Check full-slug override
  const override = LABEL_OVERRIDES[label.toLowerCase()];
  if (override) return override;
  // Title-case each hyphen-separated word, respecting known acronyms
  return label
    .split('-')
    .map((w) => WORD_CAPS[w.toLowerCase()] ?? (w.charAt(0).toUpperCase() + w.slice(1)))
    .join(' ');
}

// Title-case a nav label: capitalize each word, but keep minor words (articles,
// short prepositions/conjunctions) lowercase unless first, and preserve words that
// already carry caps/acronyms (API, ID, Salesforce, iOS). Used for API nav labels.
const TITLE_MINOR = new Set([
  'a', 'an', 'the', 'and', 'or', 'but', 'nor', 'for', 'of', 'on', 'at',
  'to', 'by', 'in', 'with', 'vs', 'via', 'per', 'as',
]);
function titleCase(label: string): string {
  return label
    .split(/\s+/)
    .map((w, i) => {
      if (!w) return w;
      // Preserve acronyms / words that already contain an uppercase letter.
      if (/[A-Z]/.test(w.slice(1)) || w === w.toUpperCase()) return w;
      if (i > 0 && TITLE_MINOR.has(w.toLowerCase())) return w.toLowerCase();
      return w.charAt(0).toUpperCase() + w.slice(1);
    })
    .join(' ');
}

// The API Reference group is rendered flat: its sub-groups (Projects, Test Cases,
// …) become static uppercase section headers with endpoint links directly beneath
// — no collapsible folders, matching the API reference design.
function isApiReferenceGroup(label: string): boolean {
  return label.trim().toLowerCase() === 'api reference';
}

// Right-pointing chevron — rotates 90° to down-pointing when open
const CARET = `<polyline points="9 18 15 12 9 6" stroke-linecap="round" stroke-linejoin="round"/>`;

// All links get the book icon; sub-groups always get their specific icon.
// depth only controls indentation — not icon visibility.
---

{!nested ? (
  /* ── Top level: always-open static section labels ── */
  <div class="ts-nav-sections">
    {sublist.map((entry) => (
      entry.type === 'group' && isApiReferenceGroup(entry.label) ? (
        /* API reference — flatten sub-groups into flat, static sections (no folders) */
        <div class="ts-api-nav">
          {entry.entries.map((child) => (
            child.type === 'group' ? (
              <div class="ts-nav-section">
                <p class="ts-section-label">{formatLabel(child.label)}</p>
                <Astro.self sublist={child.entries} nested={true} depth={1} api={true} />
              </div>
            ) : (
              <a
                href={child.href}
                aria-current={child.isCurrent ? 'page' : undefined}
                class:list={['ts-nav-item', { 'ts-nav-item--active': child.isCurrent }]}
                {...child.attrs}
              >
                {child.badge
                  ? <span class:list={['ts-method-pill', `ts-method-pill--${child.badge.variant}`]} data-method={child.badge.text}>{child.badge.text}</span>
                  : <svg class="ts-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true" set:html={iconSvg('book')} />
                }
                <span class="ts-nav-label">{titleCase(formatLabel(child.label))}</span>
              </a>
            )
          ))}
        </div>
      ) : entry.type === 'group' ? (
        <div class="ts-nav-section">
          <p class="ts-section-label">{formatLabel(entry.label)}</p>
          <Astro.self sublist={entry.entries} nested={true} depth={1} />
        </div>
      ) : (
        <a
          href={entry.href}
          aria-current={entry.isCurrent ? 'page' : undefined}
          class:list={['ts-nav-item', { 'ts-nav-item--active': entry.isCurrent, 'ts-nav-item--plain': plain }]}
        >
          {!plain && (entry.badge
            ? <span class:list={['ts-method-pill', `ts-method-pill--${entry.badge.variant}`]} data-method={entry.badge.text}>{entry.badge.text}</span>
            : <svg class="ts-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true" set:html={iconSvg('book')} />)
          }
          <span class="ts-nav-label">{formatLabel(entry.label)}</span>
        </a>
      )
    ))}
  </div>
) : (
  /* ── Nested: items inside a section or sub-group ── */
  <ul class="ts-nav-sub">
    {sublist.map((entry) => (
      <li>
        {entry.type === 'link' ? (
          <a
            href={entry.href}
            aria-current={entry.isCurrent ? 'page' : undefined}
            class:list={['ts-nav-item', { 'ts-nav-item--active': entry.isCurrent }]}
            {...entry.attrs}
          >
            {entry.badge
              ? <span class:list={['ts-method-pill', `ts-method-pill--${entry.badge.variant}`]} data-method={entry.badge.text}>{entry.badge.text}</span>
              : <svg class="ts-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true" set:html={iconSvg('book')} />
            }
            <span class="ts-nav-label">{api ? titleCase(formatLabel(entry.label)) : formatLabel(entry.label)}</span>
          </a>
        ) : (
          /* Sub-group — collapsible, chevron on right */
          <details
            class="ts-sub-details"
            open={hasCurrentDescendant(entry.entries)}
          >
            <summary class="ts-nav-item ts-nav-sub-summary">
              <svg class="ts-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true" set:html={iconSvg(iconForLabel(entry.label))} />
              <span class="ts-nav-label">{api ? titleCase(formatLabel(entry.label)) : formatLabel(entry.label)}</span>
              <svg class="ts-sub-caret" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true" set:html={CARET} />
            </summary>
            <Astro.self sublist={entry.entries} nested={true} depth={depth + 1} api={api} />
          </details>
        )}
      </li>
    ))}
  </ul>
)}

<style>
  /* ── Sections wrapper ── */
  .ts-nav-sections {
    padding: 4px 8px 24px;
  }

  /* ── Static section label ── */
  .ts-nav-section {
    margin-top: 16px;
  }
  .ts-nav-section:first-child {
    margin-top: 4px;
  }
  .ts-section-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--ts-text-primary);
    padding: 6px 8px 4px;
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    user-select: none;
  }

  /* ── Item list ── */
  .ts-nav-sub {
    list-style: none;
    margin: 0;
    padding: 0 0 4px;
  }
  /* Sub-group children: indent + left border */
  .ts-nav-sub .ts-nav-sub {
    padding-left: 18px;
    border-left: 1.5px solid var(--ts-border);
    margin-left: 13px;
    margin-top: 1px;
    padding-bottom: 2px;
  }

  /* ── Link + sub-group summary — shared item style ── */
  .ts-nav-item {
    display: flex;
    align-items: center;
    gap: 8px;
